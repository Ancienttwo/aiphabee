{
  "version": "2026-06-21.phase1.usage-quota-display-scaffold.v0",
  "status": "local_contract",
  "package": "@aiphabee/usage-ledger",
  "runtime_route": "GET /usage/runtime",
  "route": "POST /usage/quota/plan",
  "standard_response_envelope": true,
  "frontend": false,
  "live_ledger_reads": false,
  "persistent_writes": false,
  "billing_provider_reconciliation": false,
  "sql_emitted": false,
  "freshness_target_minutes": 5,
  "channels": [
    "web_agent",
    "mcp"
  ],
  "plan_codes": [
    "free",
    "plus",
    "pro",
    "developer",
    "team",
    "enterprise"
  ],
  "display_fields": [
    "request_id",
    "plan_code",
    "channel",
    "period_start",
    "period_end",
    "credit_limit",
    "credits_used",
    "credits_pending",
    "credits_remaining",
    "freshness_target_minutes"
  ],
  "required_request_fields": [
    "workspace_id",
    "channel",
    "plan_code"
  ],
  "tables": [
    "core.workspace_subscription",
    "core.usage_event",
    "core.usage_ledger_entry",
    "core.usage_reconciliation_batch"
  ],
  "request_id_visible": true,
  "linked_contracts": [
    "deploy/database/migrations.contract.json",
    "deploy/gateway/access.contract.json"
  ]
}
