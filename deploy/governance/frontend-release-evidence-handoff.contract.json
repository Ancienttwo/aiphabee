    "observed_at": "ISO-8601",
    "operator": "redacted operator label",
    "redaction_status": "missing|redacted_no_secrets|needs_redaction",
    "review_summary_hash": "sha256 hash of redacted review summary, or null",
    "route_test_hash": "sha256 hash of route/component/e2e test output, or null",
    "screenshot_hash": "sha256 hash of redacted visual evidence, or null",
    "source_locator": "redacted_file_or_external_record_id",
    "status": "missing_frontend_evidence|accepted|needs_redaction|rejected",
    "surface_id": "required frontend release surface id"
