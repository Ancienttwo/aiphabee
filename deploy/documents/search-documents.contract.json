{
  "version": "2026-06-21.phase2.semantic-document-search-scaffold.v0",
  "status": "local_contract",
  "package": "@aiphabee/document-tools",
  "runtime_route": "GET /documents/runtime",
  "route": "POST /documents/search-documents",
  "tool_name": "search_documents",
  "standard_response_envelope": true,
  "frontend": false,
  "live_data_access": false,
  "live_pgvector": false,
  "sql_emitted": false,
  "vector_search": true,
  "original_document_fetch": false,
  "covered_sprint_2_2_items": ["PRD-11.4", "pgvector_document_search"],
  "source_tools": ["search_announcements", "get_announcement", "document_sanitizer"],
  "search_contract": {
    "source": "synthetic_document_chunk_fixture",
    "search_engine": "synthetic_pgvector_scaffold",
    "index_name": "document_chunks_pgvector_synthetic",
    "embedding_model": "synthetic-text-embedding-v0",
    "pgvector_first": true,
    "vectorize_optional": true,
    "metadata_filter_pushdown": true,
    "date_basis": "published_at",
    "max_limit": 5,
    "min_score_default": 0.15,
    "sanitized_snippets_only": true,
    "untrusted_document_policy": true,
    "content_is_untrusted_data": true,
    "prompt_injection_isolated": true,
    "scripts_executable": false,
    "supported_filters": [
      "query",
      "instrument_id",
      "document_ids",
      "from",
      "to",
      "categories",
      "language",
      "min_score",
      "limit"
    ],
    "required_output_fields": [
      "results",
      "chunk_id",
      "document_id",
      "section_id",
      "sanitized_snippet",
      "similarity_score",
      "rank",
      "score_explanation",
      "source_record_id",
      "evidence_locator",
      "page",
      "paragraph",
      "metadata"
    ]
  }
}
