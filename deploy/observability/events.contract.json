{
  "version": "2026-06-20.phase0.observability.v0",
  "status": "local_contract",
  "event_types": [
    {
      "type": "run.audit",
      "required_fields": [
        "event_id",
        "event_version",
        "event_type",
        "emitted_at",
        "request_id",
        "run_id",
        "service",
        "environment",
        "route",
        "outcome",
        "attributes",
        "audit"
      ],
      "audit_required_fields": [
        "user_id",
        "workspace_id",
        "requested_tools",
        "denied_tools",
        "tool_versions",
        "tool_call_count",
        "tool_calls",
        "data_version",
        "methodology_version",
        "model_provider",
        "model_id",
        "model_version",
        "model_tier",
        "model_calls",
        "input_tokens",
        "output_tokens",
        "total_tokens",
        "estimated_cost_usd",
        "credits",
        "latency_ms",
        "output_hash"
      ],
      "tool_call_required_fields": [
        "tool_name",
        "tool_version",
        "status",
        "data_version",
        "methodology_version",
        "model_provider",
        "model_id",
        "model_version",
        "input_tokens",
        "output_tokens",
        "total_tokens",
        "estimated_cost_usd",
        "latency_ms",
        "output_hash"
      ],
      "forbidden_fields": ["prompt", "api_key", "token", "secret", "password"]
    },
    {
      "type": "run.eval",
      "required_fields": [
        "event_id",
        "event_version",
        "event_type",
        "emitted_at",
        "request_id",
        "run_id",
        "service",
        "environment",
        "route",
        "outcome",
        "attributes",
        "eval"
      ],
      "forbidden_fields": ["prompt", "api_key", "token", "secret", "password"]
    }
  ],
  "sinks": [
    {
      "name": "worker_console",
      "status": "wired",
      "purpose": "Local structured JSON log sink collected by Workers Logs when enabled.",
      "live_export_enabled": false
    },
    {
      "name": "eval_store",
      "status": "planned",
      "purpose": "Future persistent evaluation store for run quality and regression analytics.",
      "binding_name": "AIPHABEE_EVAL_STORE",
      "binding_type": "d1",
      "schema_version": "2026-06-20.phase0.eval-store.v0",
      "persistent": true,
      "writes_enabled": false
    },
    {
      "name": "otlp_destination",
      "status": "planned",
      "purpose": "Future OpenTelemetry export destination configured outside repo secrets.",
      "protocol": "otlp_http",
      "required_env": [
        "OTLP_EXPORTER_OTLP_ENDPOINT",
        "OTLP_EXPORTER_OTLP_HEADERS"
      ],
      "live_export_enabled": false
    }
  ]
}
