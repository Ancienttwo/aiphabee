{
  "version": "2026-06-21.phase1.internal-account-session-manual-plan.v0",
  "status": "local_contract",
  "package": "@aiphabee/account-runtime",
  "runtime_route": "GET /account/runtime",
  "route": "POST /account/session/plan",
  "standard_response_envelope": true,
  "frontend": false,
  "auth_provider_calls": false,
  "billing_provider_calls": false,
  "persistent_writes": false,
  "sql_emitted": false,
  "supported_login_methods": [
    "email_passwordless",
    "social_google",
    "social_github"
  ],
  "supported_session_actions": [
    "login",
    "logout",
    "refresh",
    "revoke_device",
    "revoke_session"
  ],
  "manual_plan_codes": [
    "free",
    "plus",
    "pro",
    "developer",
    "team",
    "enterprise"
  ],
  "tables": [
    "core.account",
    "core.workspace",
    "core.workspace_membership",
    "core.subscription_plan",
    "core.workspace_subscription"
  ],
  "required_request_fields": [
    "account_id",
    "workspace_id",
    "email_hash"
  ],
  "planned_outputs": [
    "account",
    "workspace",
    "session",
    "device",
    "manual_plan",
    "validation"
  ],
  "forbidden_payloads": [
    "raw_email",
    "password",
    "oauth_access_token",
    "oauth_refresh_token",
    "session_secret"
  ],
  "linked_contracts": [
    "deploy/database/migrations.contract.json",
    "deploy/gateway/access.contract.json"
  ]
}
