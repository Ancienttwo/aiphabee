{
  "version": "2026-06-22.phase0.provider-secret-live-smoke-readiness.v0",
  "status": "readiness_no_secret",
  "source_contract": "deploy/secrets/stores.contract.json",
  "script": "scripts/smoke-provider-secret-stores-live.mjs",
  "checker": "scripts/check-provider-secret-stores-live-readiness.mjs",
  "package_scripts": {
    "check": "check:provider-secret-stores-live-readiness",
    "smoke": "smoke:provider-secret-stores-live"
  },
  "synthetic_secret": {
    "name_prefix": "AIPHABEE_SECRET_STORE_SMOKE",
    "value_policy": "generated_in_memory_not_logged",
    "cleanup_required": true
  },
  "providers": [
    {
      "name": "cloudflare_workers",
      "status": "readiness_not_run",
      "required_env": [
        "CLOUDFLARE_WORKER_NAME"
      ],
      "auth_source": "Wrangler authenticated session or CLOUDFLARE_API_TOKEN",
      "commands": [
        "wrangler secret put <SMOKE_NAME> --name <CLOUDFLARE_WORKER_NAME>",
        "wrangler secret list --name <CLOUDFLARE_WORKER_NAME> --format json",
        "wrangler secret delete <SMOKE_NAME> --name <CLOUDFLARE_WORKER_NAME>"
      ],
      "operations": [
        "set_synthetic_secret",
        "list_secret_metadata",
        "rotate_synthetic_secret",
        "delete_synthetic_secret",
        "confirm_absent"
      ]
    },
    {
      "name": "github_actions",
      "status": "readiness_not_run",
      "required_env": [
        "GITHUB_REPOSITORY",
        "GITHUB_ENVIRONMENT"
      ],
      "auth_source": "gh authenticated session or GITHUB_TOKEN",
      "commands": [
        "gh secret set <SMOKE_NAME> --repo <GITHUB_REPOSITORY> --env <GITHUB_ENVIRONMENT>",
        "gh secret list --repo <GITHUB_REPOSITORY> --env <GITHUB_ENVIRONMENT> --json name,updatedAt",
        "gh secret delete <SMOKE_NAME> --repo <GITHUB_REPOSITORY> --env <GITHUB_ENVIRONMENT>"
      ],
      "operations": [
        "set_synthetic_secret",
        "list_secret_metadata",
        "rotate_synthetic_secret",
        "delete_synthetic_secret",
        "confirm_absent"
      ]
    },
    {
      "name": "supabase",
      "status": "readiness_not_run",
      "required_env": [
        "SUPABASE_PROJECT_REF"
      ],
      "auth_source": "Supabase authenticated session or SUPABASE_ACCESS_TOKEN",
      "commands": [
        "supabase secrets set --env-file <TEMP_ENV_FILE> --project-ref <SUPABASE_PROJECT_REF>",
        "supabase secrets list --project-ref <SUPABASE_PROJECT_REF> --output json",
        "supabase secrets unset <SMOKE_NAME> --project-ref <SUPABASE_PROJECT_REF> --yes"
      ],
      "operations": [
        "set_synthetic_secret",
        "list_secret_metadata",
        "rotate_synthetic_secret",
        "delete_synthetic_secret",
        "confirm_absent"
      ]
    }
  ],
  "pass_conditions": [
    "synthetic secret can be set in each provider store",
    "provider list command confirms the synthetic secret metadata is present",
    "second set updates the same synthetic secret name as a rotation smoke",
    "delete or unset command removes the synthetic secret",
    "final list command confirms the synthetic secret metadata is absent"
  ],
  "forbidden_output_fields": [
    "authorization",
    "api_key",
    "token",
    "secret_value",
    "raw_value",
    "raw_output",
    "env_file_contents"
  ],
  "not_claimed": [
    "production secret values exist",
    "production provider secrets rotated",
    "incident runbook executed",
    "OIDC replacement implemented",
    "live smoke passed"
  ]
}
