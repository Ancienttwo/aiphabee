{
  "version": "2026-06-21.phase1.tool-loop-agent-planner-scaffold.v0",
  "status": "local_contract",
  "package": "@aiphabee/agent-runtime",
  "route": "POST /agent/runs/plan",
  "stream_route": "POST /agent/runs/stream",
  "runtime_route": "GET /agent/runtime",
  "model_calls": false,
  "actual_tool_execution": false,
  "streaming_transport": "server_sent_events",
  "stream_content_type": "text/event-stream",
  "stream_model_calls": false,
  "stream_actual_tool_execution": false,
  "chain_of_thought_exposed": false,
  "frontend": false,
  "max_steps": 6,
  "supported_max_steps": 8,
  "max_parallel_tools": 3,
  "retry_policy": {
    "max_attempts_per_tool": 2,
    "consecutive_same_error_limit": 2,
    "retry_billable": false
  },
  "required_step_phases": [
    "security_resolution",
    "entitlement_gate",
    "data_fetch",
    "evidence_binding",
    "answer_contract"
  ],
  "required_progress_events": [
    "run.started",
    "tool.step.planned",
    "tool.call.started",
    "tool.call.completed",
    "tool.call.failed",
    "run.completed",
    "run.stopped"
  ],
  "required_stop_conditions": [
    "max_steps",
    "budget_exhausted",
    "two_consecutive_same_error",
    "tool_scope_denied",
    "all_planned_tools_completed"
  ],
  "required_tool_call_fields": [
    "name",
    "version",
    "input_schema_id",
    "output_schema_id",
    "required_scope",
    "live_data_access",
    "execution"
  ]
}
