{
  "version": "2026-06-21.phase3.product-agent-release-gate-scaffold.v0",
  "status": "local_contract",
  "package": "@aiphabee/agent-runtime",
  "runtime_route": "GET /agent/runtime",
  "route": "POST /agent/release-gates/product-agent/plan",
  "preflight_route": "POST /agent/runs/preflight",
  "tool_loop_route": "POST /agent/runs/plan",
  "standard_response_envelope": true,
  "frontend_rendering": false,
  "persistent_writes": false,
  "live_db_writes": false,
  "live_tool_execution": false,
  "model_calls": false,
  "sql_emitted": false,
  "silent_security_selection_allowed": false,
  "ambiguous_security_must_block_tool_planning": true,
  "concrete_numbers_allowed_without_sources": false,
  "numeric_allowed_sources": ["tool_result", "deterministic_calculation"],
  "numeric_blocked_sources": [
    "model_memory",
    "training_data",
    "unverified_prompt",
    "unstated_source"
  ],
  "required_claim_labels": ["fact", "calculation", "inference", "unknown"],
  "required_checks": [
    "ambiguous_security_blocks_tool_planning",
    "silent_security_selection_blocked",
    "numeric_claim_requires_tool_result_or_calculation_ref",
    "post_generation_unsourced_numeric_claim_blocked",
    "answer_contract_blocks_unsourced_numbers",
    "deterministic_calculations_keep_model_out"
  ],
  "required_output_fields": [
    "ambiguous_security_gate",
    "numeric_evidence_gate",
    "answer_contract_gate",
    "post_generation_evidence_binding",
    "release_checks",
    "validation"
  ],
  "release_gate": {
    "gate_status": "blocked_live_evidence_binding",
    "no_live_release_claim": true,
    "required_signoffs": ["product", "agent", "data_quality"],
    "blockers": [
      "live_evidence_binding_missing",
      "frontend_clarification_ui_missing"
    ]
  },
  "tables": [
    "aiphabee_core.product_agent_release_gate",
    "aiphabee_governance.product_agent_release_gate_contract"
  ],
  "covered_sprint_3_3_items": [
    "security_ambiguity_no_silent_selection",
    "numeric_claims_evidence_bound"
  ],
  "linked_contracts": [
    "deploy/agent/pre-tool-call-resolution.contract.json",
    "deploy/agent/numeric-source-guard.contract.json",
    "deploy/agent/answer-evidence-contract.contract.json",
    "deploy/governance/post-generation-evidence-binding.contract.json",
    "deploy/database/migrations.contract.json"
  ]
}
