{
  "version": "2026-06-20.phase0.database-migrations.v0",
  "status": "local_contract",
  "provider": "supabase_postgres",
  "connection_path": "cloudflare_hyperdrive",
  "migration_directory": "supabase/migrations",
  "hyperdrive": {
    "binding": "AIPHABEE_HYPERDRIVE",
    "status": "planned",
    "wrangler_binding_requires_real_id": true,
    "local_dev_secret_env": "CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_AIPHABEE_HYPERDRIVE",
    "smoke_test": "Run read-only SELECT 1 through Hyperdrive after resource provisioning."
  },
  "commands": [
    {
      "name": "create_migration",
      "command": "supabase migration new <name>",
      "effect": "local_file"
    },
    {
      "name": "apply_local",
      "command": "supabase migration up --local",
      "effect": "local_database"
    },
    {
      "name": "dry_run_remote",
      "command": "supabase db push --dry-run --db-url \"$HYPERDRIVE_DATABASE_URL\"",
      "effect": "remote_dry_run"
    },
    {
      "name": "apply_remote",
      "command": "supabase db push --db-url \"$HYPERDRIVE_DATABASE_URL\"",
      "effect": "remote_database"
    }
  ],
  "migrations": [
    {
      "file": "supabase/migrations/20260620071000_phase0_foundation.sql",
      "purpose": "Create non-market-data schemas and default-deny governance controls used by later data-access slices.",
      "schemas": ["audit", "core", "governance"],
      "tables": [
        "governance.data_rights_channel_status",
        "governance.phase0_migration_contract"
      ],
      "market_data": false,
      "default_rights_status": "default_deny"
    },
    {
      "file": "supabase/migrations/20260620082000_security_master_raw_snapshot_scaffold.sql",
      "purpose": "Create empty security master and immutable raw snapshot scaffolds for Sprint 1.1 without loading partner or market data.",
      "schemas": ["core", "governance"],
      "tables": [
        "core.company",
        "core.data_version_batch",
        "core.identifier_history",
        "core.instrument",
        "core.listing",
        "core.raw_snapshot",
        "core.raw_source_batch",
        "governance.security_master_contract"
      ],
      "market_data": false,
      "default_rights_status": "default_deny"
    },
    {
      "file": "supabase/migrations/20260620083000_financial_facts_restatement_scaffold.sql",
      "purpose": "Create empty financial facts and restatement scaffolds for Sprint 1.1 without loading partner or market data.",
      "schemas": ["core", "governance"],
      "tables": [
        "core.financial_fact",
        "core.financial_restatement",
        "core.financial_statement",
        "governance.financial_facts_contract"
      ],
      "market_data": false,
      "default_rights_status": "default_deny"
    },
    {
      "file": "supabase/migrations/20260620084000_corporate_action_adjustment_scaffold.sql",
      "purpose": "Create empty corporate action and price adjustment scaffolds for Sprint 1.1 without loading partner or market data.",
      "schemas": ["core", "governance"],
      "tables": [
        "core.adjustment_methodology",
        "core.corporate_action",
        "core.price_adjustment_factor",
        "governance.corporate_action_adjustment_contract"
      ],
      "market_data": false,
      "default_rights_status": "default_deny"
    },
    {
      "file": "supabase/migrations/20260620085000_account_workspace_entitlement_scaffold.sql",
      "purpose": "Create empty account, workspace, subscription, and entitlement scaffolds for Sprint 1.1 without loading partner or market data.",
      "schemas": ["core", "governance"],
      "tables": [
        "core.account",
        "core.data_entitlement",
        "core.subscription_plan",
        "core.workspace",
        "core.workspace_entitlement",
        "core.workspace_membership",
        "core.workspace_subscription",
        "governance.account_workspace_entitlement_contract"
      ],
      "market_data": false,
      "default_rights_status": "default_deny"
    }
  ]
}
