{
  "version": "2026-06-21.phase1.get-market-calendar-tool-scaffold.v0",
  "status": "local_contract",
  "tool_name": "get_market_calendar",
  "route": "POST /tools/get-market-calendar",
  "handler_ready": true,
  "live_data_access": false,
  "allow_arbitrary_sql": false,
  "allow_arbitrary_url": false,
  "standard_response_envelope": true,
  "supported_inputs": ["market", "from", "to"],
  "supported_markets": ["HK"],
  "timezone": "Asia/Hong_Kong",
  "supported_session_statuses": ["trading_day", "half_day", "closed"],
  "supported_closure_reasons": ["weather", "holiday", "weekend"],
  "required_statuses": ["found", "not_found", "out_of_range"],
  "required_session_fields": [
    "date",
    "market",
    "timezone",
    "sessionStatus",
    "isTradingDay",
    "notes"
  ],
  "required_error_codes": ["NOT_FOUND", "OUT_OF_RANGE", "SCOPE_DENIED"],
  "fixture_cases": [
    "trading_day",
    "half_day",
    "weather_closure",
    "holiday_closure",
    "weekend_closure",
    "unsupported_market",
    "out_of_range"
  ]
}
