{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "apps/ipo-workbench/**",
              "components/core/**",
              "components/data/**",
              "components/forms/**",
              "components/mascot/**",
              "ui_kits/ipo-agent/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|JetBrains Mono|Noto Sans SC))/i]",
        "message": "Font not provided by the design system. Available: Inter, JetBrains Mono, Noto Sans SC."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|variant|size|dot|dotShape|icon|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, variant, size, dot, dotShape, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:honey|navy|neutral|bullish|bearish|ai|info|warning)$/]",
        "message": "<Badge> tone must be one of 'honey' | 'navy' | 'neutral' | 'bullish' | 'bearish' | 'ai' | 'info' | 'warning'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|solid|outline)$/]",
        "message": "<Badge> variant must be one of 'soft' | 'solid' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='dotShape'] > Literal[value!=/^(?:hex|round)$/]",
        "message": "<Badge> dotShape must be one of 'hex' | 'round'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BeeNote'] > JSXAttribute > JSXIdentifier[name!=/^(?:pose|basePath|src|title|tone|mascotSize|action|children|key|ref|className|style|children)$/]",
        "message": "<BeeNote> doesn't accept that prop. Declared props: pose, basePath, src, title, tone, mascotSize, action, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='BeeNote'] > JSXAttribute[name.name='pose'] > Literal[value!=/^(?:insight|thinking|success|risk|greeting|forage|empty|avatar)$/]",
        "message": "<BeeNote> pose must be one of 'insight' | 'thinking' | 'success' | 'risk' | 'greeting' | 'forage' | 'empty' | 'avatar'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BeeNote'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:honey|navy)$/]",
        "message": "<BeeNote> tone must be one of 'honey' | 'navy'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|fullWidth|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, fullWidth, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|outline|ghost|ai|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'outline' | 'ghost' | 'ai' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:interactive|padded|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: interactive, padded, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='CompareSide'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|ticker|color|key|ref|className|style|children)$/]",
        "message": "<CompareSide> doesn't accept that prop. Declared props: name, ticker, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='ForageLoader'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|doneLabel|done|variant|basePath|src|key|ref|className|style|children)$/]",
        "message": "<ForageLoader> doesn't accept that prop. Declared props: label, doneLabel, done, variant, basePath, src."
      },
      {
        "selector": "JSXOpeningElement[name.name='ForageLoader'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:pill|block)$/]",
        "message": "<ForageLoader> variant must be one of 'pill' | 'block'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Hexvatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:imgSrc|alt|icon|size|tone|variant|clip|children|key|ref|className|style|children)$/]",
        "message": "<Hexvatar> doesn't accept that prop. Declared props: imgSrc, alt, icon, size, tone, variant, clip, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Hexvatar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:honey|navy|green|violet|red|neutral)$/]",
        "message": "<Hexvatar> tone must be one of 'honey' | 'navy' | 'green' | 'violet' | 'red' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Hexvatar'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:fill|soft|outline)$/]",
        "message": "<Hexvatar> variant must be one of 'fill' | 'soft' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|prefix|suffix|helper|error|size|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, icon, prefix, suffix, helper, error, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MascotState'] > JSXAttribute > JSXIdentifier[name!=/^(?:pose|basePath|src|title|description|size|comb|children|key|ref|className|style|children)$/]",
        "message": "<MascotState> doesn't accept that prop. Declared props: pose, basePath, src, title, description, size, comb, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='MascotState'] > JSXAttribute[name.name='pose'] > Literal[value!=/^(?:empty|success|risk|thinking|greeting|forage|insight|compare|honey-finish)$/]",
        "message": "<MascotState> pose must be one of 'empty' | 'success' | 'risk' | 'thinking' | 'greeting' | 'forage' | 'insight' | 'compare' | 'honey-finish'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RatingStars'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|count|size|showValue|reviews|color|emptyColor|key|ref|className|style|children)$/]",
        "message": "<RatingStars> doesn't accept that prop. Declared props: value, count, size, showValue, reviews, color, emptyColor."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScoreMeter'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|label|tone|labels|showValue|key|ref|className|style|children)$/]",
        "message": "<ScoreMeter> doesn't accept that prop. Declared props: value, max, label, tone, labels, showValue."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScoreMeter'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:bullish|cautious|neutral|bearish|honey|ai)$/]",
        "message": "<ScoreMeter> tone must be one of 'bullish' | 'cautious' | 'neutral' | 'bearish' | 'honey' | 'ai'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|icon|tone|delta|deltaDirection|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: label, value, icon, tone, delta, deltaDirection."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:honey|navy|green|violet|blue|red)$/]",
        "message": "<StatCard> tone must be one of 'honey' | 'navy' | 'green' | 'violet' | 'blue' | 'red'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='deltaDirection'] > Literal[value!=/^(?:up|down|flat)$/]",
        "message": "<StatCard> deltaDirection must be one of 'up' | 'down' | 'flat'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
